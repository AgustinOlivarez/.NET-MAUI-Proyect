<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MauiApp1.ViewModels"
             x:Class="MauiApp1.Views.PlayerDetailPage"
             x:DataType="viewmodels:PlayerDetailViewModel"
             Title="Perfil del Jugador"
             BackgroundColor="#12181b">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20" HorizontalOptions="Center" MaximumWidthRequest="400">

            <Border Padding="25" Stroke="#2a363f" BackgroundColor="#1e262c" Margin="0,15,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="15" HorizontalOptions="Center">

                    <Border HeightRequest="150" WidthRequest="150" Padding="0" HorizontalOptions="Center" Stroke="#00E676" StrokeThickness="2">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="75" />
                        </Border.StrokeShape>
                        <Image Source="{Binding Player.ImagePath}" Aspect="AspectFill" />
                    </Border>

                    <Entry Text="{Binding Player.Nombre}" FontSize="24" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="#F5F5F5" BackgroundColor="Transparent" />

                    <BoxView HeightRequest="1" Color="#2a363f" Margin="0,10" />

                    <Label Text="Posición" FontSize="13" TextColor="#9BA4B5" TextTransform="Uppercase" />
                    <Entry Text="{Binding Player.Posicion}" FontSize="18" FontAttributes="Bold" TextColor="#F5F5F5" BackgroundColor="Transparent" Margin="0,-10,0,0"/>

                    <Label Text="Equipo Actual" FontSize="13" TextColor="#9BA4B5" TextTransform="Uppercase" Margin="0,10,0,0" />
                    <Entry Text="{Binding Player.Equipo}" FontSize="18" FontAttributes="Bold" TextColor="#00E676" BackgroundColor="Transparent" Margin="0,-10,0,0"/>

                    <Label Text="Coordenadas GPS" FontSize="13" TextColor="#9BA4B5" TextTransform="Uppercase" Margin="0,10,0,0" />
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="LAT:" FontSize="14" FontAttributes="Bold" TextColor="#00E676" />
                        <Label Text="{Binding Player.Latitude}" FontSize="14" TextColor="#F5F5F5" />
                        <Label Text="LON:" FontSize="14" FontAttributes="Bold" TextColor="#00E676" Margin="10,0,0,0" />
                        <Label Text="{Binding Player.Longitude}" FontSize="14" TextColor="#F5F5F5" />
                    </HorizontalStackLayout>

                    <Button Text="Guardar Cambios" 
                            Command="{Binding SaveChangesCommand}" 
                            BackgroundColor="#00E676" 
                            TextColor="#12181b" 
                            CornerRadius="8" 
                            FontAttributes="Bold" 
                            Margin="0,20,0,0"/>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>