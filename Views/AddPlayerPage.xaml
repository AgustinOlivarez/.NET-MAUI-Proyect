<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MauiApp1.ViewModels"
             xmlns:models="clr-namespace:MauiApp1.Models;assembly=MauiApp1.Core"
             x:Class="MauiApp1.Views.AddPlayerPage"
             x:DataType="viewmodels:AddPlayerViewModel"
             Title="Nuevo Fichaje"
             BackgroundColor="#12181b">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Border Padding="20" BackgroundColor="#1e262c" Stroke="#2a363f">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="15">

                    <Label Text="Datos del Recluta" FontSize="22" FontAttributes="Bold" TextColor="#F5F5F5" Margin="0,0,0,10" />

                    <Entry Placeholder="Nombre completo" Text="{Binding Nombre}" BackgroundColor="#12181b" TextColor="#F5F5F5" PlaceholderColor="#9BA4B5" />
                    <Entry Placeholder="Posición" Text="{Binding Posicion}" BackgroundColor="#12181b" TextColor="#F5F5F5" PlaceholderColor="#9BA4B5" />
                    <Entry Placeholder="Equipo" Text="{Binding Equipo}" BackgroundColor="#12181b" TextColor="#F5F5F5" PlaceholderColor="#9BA4B5" />

                    <Border HeightRequest="150" WidthRequest="150" Padding="0" HorizontalOptions="Center" BackgroundColor="#12181b" Stroke="#2a363f" StrokeThickness="2" Margin="0,10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="75" />
                        </Border.StrokeShape>
                        <Grid>
                            <Label Text="Sin foto" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#9BA4B5" FontSize="14" />
                            <Image Source="{Binding ImagePath}" Aspect="AspectFill" />
                        </Grid>
                    </Border>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="📷 Cámara" Command="{Binding CapturePhotoCommand}" BackgroundColor="#2a363f" TextColor="#F5F5F5" CornerRadius="8" FontSize="13" />
                        <Button Grid.Column="1" Text="📍 Usar GPS" Command="{Binding GetLocationCommand}" BackgroundColor="#2a363f" TextColor="#F5F5F5" CornerRadius="8" FontSize="13" />
                    </Grid>

                    <Label Text="{Binding StatusMessage}" TextColor="#FF5252" HorizontalOptions="Center" FontSize="13" FontAttributes="Bold" />

                    <BoxView HeightRequest="1" Color="#2a363f" Margin="0,10" />

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="Descartar" Command="{Binding ClearCommand}" BackgroundColor="#2a363f" TextColor="#9BA4B5" CornerRadius="8" />

                        <Button Grid.Column="1" Text="Registrar" Command="{Binding SaveCommand}" BackgroundColor="#00E676" TextColor="#12181b" CornerRadius="8" FontAttributes="Bold" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>